{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "brainsales-companion",
  "version": "1.2.0",
  "identifier": "com.iian.brainsales-companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Brainsales Companion",
        "width": 320,
        "height": 200,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/appicon.ico"
    ]
  },
  "plugins": {
    "updater": {
